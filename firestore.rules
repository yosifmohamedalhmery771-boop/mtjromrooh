rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Settings collection
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Products collection
    match /products/{productId} {
      allow read, write: if true;
    }

    // Delivery Locations collection
    match /locations/{locationId} {
      allow read, write: if true;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Orders collection
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Gifts collection
    match /gifts/{giftId} {
      allow read, write: if true;
    }

    // Recharges collection
    match /recharges/{rechargeId} {
      allow read, write: if true;
    }

    // Phone Requests collection
    match /phone_requests/{requestId} {
      allow read, write: if true;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // Targeted Notifications collection
    match /targeted_notifications/{notificationId} {
      allow read, write: if true;
    }

    // Targeted Gifts collection
    match /targeted_gifts/{giftId} {
      allow read, write: if true;
    }

    // Targeted Gift Logs collection
    match /targeted_gift_logs/{logId} {
      allow read, write: if true;
    }
  }
}
